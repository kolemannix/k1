fn example-fs() {
  // let l = alloc-mode:current.alloc-t[uv/uv_loop_t];
  // uv/uv_loop_init(l);
  let l = uv/default_loop()

  // let idler: uv/uv_idle_t = uninit;
  // uv/uv_idle_init(l, &idler);
  // uv/uv_idle_start(&idler, wait_for_a_while);

  let open-req: uv/fs = uninit
  let flags =  core/posix/O_RDWR
  let uv-file = uv/fs_open(l, &open-req, ($string/c-lit("uv.k1")).rw[u8], flags, 0, ptr/null.as())
  if uv-file < 0 {
    println("open error: {uv-file}")
    crash("")
  }
  let data-buffer = buffer/allocate[u8](1024)
  let uvbuf = uv/buf/wrap-buffer(data-buffer)
  let read-req: uv/fs = uninit
  read-req.set-data(&data-buffer)

  uv/fs_read(l, &read-req, uv-file, &uvbuf, 1, offset = 0, fn uv-fs. {
    let data: *mut buffer[u8] = uv-fs.get-data()
    let result: size = uv/fs_get_result(uv-fs)
    let s = string/wrap-byte-buffer(data)
    tprintln("done read: {result}. data={data.len}\n{s}")
  })

  println("idling")
  uv/run(l, :UV_RUN_DEFAULT)

  println("Now quitting.")
  uv/loop_close(l)

  .{}
}

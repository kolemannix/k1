build:
  k1 b .

run:
  k1 r .

bindgen: bindgen-llhttp bindgen-net bindgen-libuv

bindgen-llhttp:
  k1bindgen -i libs/llhttp.h -o llhttp.k1 -n llhttp \
    -clangarg -isysroot \
    -clangarg "$(xcrun --sdk macosx --show-sdk-path)" \
    -exclude llhttp__internal_init \
    -exclude llhttp__internal_execute

bindgen-net:
  k1bindgen -i net.c -o net.k1 -n net \
    -clangarg -isysroot \
    -clangarg "$(xcrun --sdk macosx --show-sdk-path)" \
    -system true \
    -include sockaddr_in \
    -include sockaddr_in6 \
    -include sa_family_t \
    -include sockaddr \
    -include socklen_t \
    -opaque socklen_t \
    -include addrinfo \
    -include in_port_t \
    -include in_addr \
    -include in6_addr \
    -include in_addr_t \
    -include FILE \
    -opaque FILE

bindgen-libuv:
  k1bindgen -i libs/libuv/include/uv.h -o uv.k1 -n uv \
    -clangarg -Ilibs/libuv/include \
    -system false \
    -clangarg -isysroot \
    -clangarg "$(xcrun --sdk macosx --show-sdk-path)" \
    -prelude-file uv_bindgen_prelude.k1.txt \
    -rename uv_loop_t uv-loop \
    -rename uv_fs_event fs_event_kind \
    -strip-prefix uv_ \
    -strip-suffix _t \
    -opaque uv__dirent_t \
    -opaque uv_uid_t \
    -opaque uv_gid_t \
    -opaque uv_pid_t \
    -opaque uv_once_t \
    -opaque uv_thread_t \
    -opaque uv_mutex_t \
    -opaque uv_rwlock_t \
    -opaque uv_sem_t \
    -opaque uv_cond_t \
    -opaque uv_key_t \
    -opaque _uv_barrier \
    -exclude uv_loop_s$ \
    -opaque uv_loop_t \
    -opaque uv_connect_t \
    -exclude uv_connect_s$ \
    -opaque uv_shutdown_t \
    -exclude uv_shutdown_s$ \
    -opaque uv_handle_t \
    -exclude uv_handle_s$ \
    -opaque uv_fs_event_t \
    -exclude uv_fs_event_s$ \
    -opaque uv_fs_poll_t \
    -exclude uv_fs_poll_s$ \
    -opaque uv_any_handle \
    -opaque uv_any_req \
    -exclude uv_stream_s$ \
    -opaque uv_stream_t \
    -opaque uv_tcp_t \
    -exclude uv_tcp_s$ \
    -opaque uv_udp_t \
    -exclude uv_udp_s$ \
    -opaque uv_udp_send_t \
    -exclude uv_udp_send_s$ \
    -opaque uv_work_t \
    -exclude uv_work_s$ \
    -opaque uv_pipe_t \
    -exclude uv_pipe_s$ \
    -opaque uv_tty_t \
    -exclude uv_tty_s$ \
    -opaque uv_fs_t \
    -exclude uv_fs_s$ \
    -opaque uv_req_t \
    -exclude uv_req_s$ \
    -opaque uv_random_t \
    -exclude uv_random_s$ \
    -opaque uv_poll_t \
    -exclude uv_poll_s$ \
    -opaque uv_dir_t \
    -exclude uv_dir_s$ \
    -opaque uv_getaddrinfo_t \
    -exclude uv_getaddrinfo_s$ \
    -opaque uv_getnameinfo_t \
    -exclude uv_getnameinfo_s$ \
    -opaque uv_timer_t \
    -exclude uv_timer_s$ \
    -opaque uv_prepare_t \
    -exclude uv_prepare_s$ \
    -opaque uv_check_t \
    -exclude uv_check_s$ \
    -opaque uv_idle_t \
    -exclude uv_idle_s$ \
    -opaque uv_async_t \
    -exclude uv_async_s$ \
    -opaque uv_process_t \
    -exclude uv_process_s$ \
    -opaque uv_fs_poll_t \
    -opaque uv_signal_t \
    -exclude uv_signal_s$ \
    -exclude uv__ \
    -opaque uv_write_t \
    -exclude uv_write_s$ \
    -exclude UV_OVERLAPPED_PIPE

build-llhttp:
  git submodule update llhttp
  cd llhttp && \
    npm ci && \
    make
  cp llhttp/build/libllhttp.a libs/
  cp llhttp/build/libllhttp.so libs/
  cp llhttp/build/llhttp.h libs/

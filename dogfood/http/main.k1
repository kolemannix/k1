type db-conn = {

}

ns for db-conn {
  fn run-query-task(_self: db-conn, uv-loop: *mut uv-loop, query: string): task[result[int, string]] {
    task/spawn(
      uv-loop,
      fake-database-query,
      { query },
    )
  }
  fn run-query(_self: db-conn, query: string): result[int, string] {
    fake-database-query({ query })
  }

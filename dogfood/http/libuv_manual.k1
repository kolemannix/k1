ns libuv;

deftype uv_loop_s = {
  // User data - use this for whatever
  data: ptr,
  // Loop reference counting. 
  active_handles: u32,
  handle_queue: uv__queue,
  // abi-equivalent to union
  // union {
  //   void* unused;
  //   unsigned int count;
  // } active_reqs;
  active_reqs: ptr,
  // Internal storage for future extensions.
  internal_fields: ptr,
  // Internal flag to signal loop stop.
  stop_flag: i32,
  UV_LOOP_PRIVATE_FIELDS
}

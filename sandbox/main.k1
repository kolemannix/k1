ns foo {
  fn stuff(): int { 33 }
}

fn repeat(n: int, a: string): string {
  let sb = StringBuilder/new();
  for IntRange/upTo(n) { sb.write-string("{a};") };
  sb.build()
}

ns foo {
  fn more-stuff() { {} }
}

fn main(): i32 {
  let f = fn. 10;
  f();
  core/println("");
  core/compiler/location();
  list/empty[u64]();
  0
}

macro for-each(binding: ?string, iterable, body) {
  // let iter   = meta/fresh-name("iter")
  let iter = "iter"
  let binding = binding ? "it"
  `{
    let $iter = $iterable.iterator()
    let it-index: size = 0
    loop {
      if $iter.next() is :some($binding) {
        $body
        it-index = it-index + 1
      } else break
    }
  }`
}

#debug fn main(): i32 {
  for-each(:none, [1,2,3], {
    println(foo);
    it;
  })

  0
}

fn discard-check() { let _ = 42 }

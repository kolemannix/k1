ns foo {
  fn stuff(): int { 33 }
}

fn repeat(n: int, a: string): string {
  let sb = StringBuilder/new();

  4u8 + 3u8;
  4 + 3;

  for IntRange/upTo(n) { sb.write-string("{a};") };
  sb.build()
}

ns foo {
  fn more-stuff() { {} }
}

fn main(): i32 {
  let i = 4;
  let f = fn. i + 10;
  f();
  core/println("");
  core/compiler/location();
  list/empty[u64]();
  0
}

fn single-never(b: bool): int {
  let x: int = if not b crash("Uh oh!") else 0
  let y: int = if b 0 else crash("Uh oh!")
  x + y
}

fn both-never(b: bool): int {
  let x: int = if not b {
    crash("Uh oh!")
  } else {
    crash("Ahh!")
  }
}

fn main(): i32 {
  assert(single-never(true) == 0)
  both-never(false)
  0
}

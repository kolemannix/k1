let MODULE_INFO: k1/module-manifest = {
  kind: :executable,
  deps: [],
  multithreading: false,
  libs: [{ name: "foo", link-type: :static }],
  link-args: [],
}

ns foo {

  type VerySmall = { x: u8 }
  impl print for VerySmall { fn printTo[w: writer](self: VerySmall, w) { w.string("{ {self.x} }") } }
  impl equals for VerySmall { fn equals(self: VerySmall, other: VerySmall): bool { self.x == other.x } }
  extern("foo", "very_small") fn very_small(x: VerySmall, y: VerySmall): VerySmall

  type IntWrap = { inner: i32 }
  extern("foo", "intWrap") fn intWrap(a: IntWrap, b: IntWrap): IntWrap

  type Small = { r: u8, g: u8, b: u8, a: u8 }
  extern("foo", "small")      fn small(x: Small, y: Small): Small

  type Medium = { a: u64, b: u64 }
  extern("foo", "medium")     fn medium(a: Medium, b: Medium): Medium

  type MixedClassMedium = { f1: f32, f2: f32, i3: array[i16, 4] }

  type Large = { med1: Medium, med2: Medium }
  extern("foo", "large")      fn large(a: Large, b: Large): Large

  type HFA2 = { x: f32, y: f32 }
  extern("foo", "hfa2_add") fn hfa2-add(a: HFA2, b: HFA2): HFA2

  type HFA1 = { x: f32 }
  type HFANested3 = { a: HFA1, b: f32, c: f32 }
  extern("foo", "hfa_nested3_add") fn hfa-nested3-add(a: HFANested3, b: HFANested3): HFANested3

  type HFA4 = { a: f64, b: f64, c: f64, d: f64 }
  extern("foo", "hfa4_add") fn hfa4-add(a: HFA4, b: HFA4): HFA4

  type CXCursorKind = either(u32) { UnexposedDecl = 1, StructDecl = 2 }
  type CXCursor = {
    kind: CXCursorKind,
    xdata: i32,
    data: array[ptr, 3]
  }

  extern("foo", "rtCursor") fn rtCursor(c: CXCursor): CXCursor

  type CXString = {
    data: ptr,
    private_flags: u32,
  }
  extern("foo", "getFileName") fn getFileName(SFile: ptr): CXString 

  type CXSourceLocation = {
    ptr_data: array[ptr, 2],
    int_data: u32,
  }
  extern("foo", "getCursorLocation")
  fn getCursorLocation(c: CXCursor): CXSourceLocation 

  extern("foo", "takesFn")
  fn takes-fn(f: *fn(a: u64, b: u64, c: u64, d: u64) -> i32): i32

  extern("foo", "takesFnStruct")
  fn takes-fn-struct(f: *fn(s: { a: u64, b: u64, c: u64, d: u64 }) -> i32): i32

  type TagUnion = either(u32) { a(i32) = 0, b(i64) = 1, c(ptr) = 2 }
  extern("foo", "TagUnion_iszero") fn TagUnion_iszero(x: TagUnion): i32

}

fn testAll() {
  assertEquals(
    foo/very_small({ x: 10 }, { x: 20 }),
    { x: 30 }
  );

  let smallResult = foo/small({r: 1, g: 10, b: 20, a: 30 }, { r: 1, g: 1, b: 1, a: 1 });
  assertEquals(smallResult.r, 2);
  assertEquals(smallResult.g, 11);
  assertEquals(smallResult.b, 21);
  assertEquals(smallResult.a, 31);

  let intWrapResult = foo/intWrap({ inner: -5 }, { inner: 10 });
  assertEquals(intWrapResult.inner, 5);

  let mediumResult = foo/medium({ a: 10, b: 100 }, { a: 1, b: 20 });
  assertEquals(mediumResult.a, 11);
  assertEquals(mediumResult.b, 120);

  let largeResult = foo/large(
    { med1: { a: 1, b: 2 }, med2: { a: 3, b: 4 } },
    { med1: { a: 10, b: 20 }, med2: { a: 30, b: 40 } }
  );
  assertEquals(largeResult.med1.a, 11);
  assertEquals(largeResult.med1.b, 22);
  assertEquals(largeResult.med2.a, 33);
  assertEquals(largeResult.med2.b, 44);

  let hfa2 = foo/hfa2-add({ x: 1.0, y: 2.0 }, { x: 10.0, y: 20.0 });
  assertEquals(hfa2.x, 11.0);
  assertEquals(hfa2.y, 22.0);

  let hfaNested3 = foo/hfa-nested3-add(
    { a: { x: 1.0 }, b: 2.0, c: 3.0 },
    { a: { x: 10.0 }, b: 20.0, c: 30.0 }
  );
  assertEquals(hfaNested3.a.x, 11.0);
  assertEquals(hfaNested3.b, 22.0);
  assertEquals(hfaNested3.c, 33.0);

  let hfa4 = foo/hfa4-add(
    { a: 1.0, b: 2.0, c: 3.0, d: 4.0 },
    { a: 10.0, b: 20.0, c: 30.0, d: 40.0 }
  );
  assertEquals(hfa4.a, 11.0);
  assertEquals(hfa4.b, 22.0);
  assertEquals(hfa4.c, 33.0);
  assertEquals(hfa4.d, 44.0);

  let cursor: foo/CXCursor = {
    kind: :UnexposedDecl,
    xdata: -42,
    data: [1.as[ptr], 2.as[ptr], 3.as[ptr]]
  };
  let rt = foo/rtCursor(cursor);
  assertEquals(cursor.kind.enum-value(), rt.kind.enum-value());
  assertEquals(cursor.xdata, rt.xdata);
  assertEquals(cursor.data.get(0), rt.data.get(0));
  assertEquals(cursor.data.get(1), rt.data.get(1));
  assertEquals(cursor.data.get(2), rt.data.get(2));

  let n = foo/getFileName(ptr/null);
  assertEquals(n.data.as[size], 3);
  assertEquals(n.private_flags, 21);

  let locn = foo/getCursorLocation(rt);
  assertEquals(locn.ptr_data.get(0), 1.as[ptr]);
  assertEquals(locn.ptr_data.get(1), 2.as[ptr]);
  assertEquals(locn.int_data, 42);

  assert(not foo/TagUnion_iszero(:a(10)).as-bool());
  assert(    foo/TagUnion_iszero(:a(0)).as-bool());

  assert(not foo/TagUnion_iszero(:b(10)).as-bool());
  assert(    foo/TagUnion_iszero(:b(0)).as-bool());

  assert(foo/TagUnion_iszero(:c(ptr/null)).as-bool());
  let x = 10;
  assert(not foo/TagUnion_iszero(:c(&x.as())).as-bool());

}

fn testFnPtr() {
  // We don't run this one at compile-time because there is no actual function to pass.
  // FIXME: You can't pass a k1 function to a compiled library at comptime
  //        since the function pointer doesn't exist; we'd have to JIT the function.
  //        We should prevent this, somehow

  let sum = foo/takes-fn(sum-fn);
  assertEquals(sum, 1+2+3+4);

  let sum2 = foo/takes-fn-struct(sum-fn-struct);
  assertEquals(sum2, 1+2+3+4);
}

fn sum-fn(a: u64, b: u64, c: u64, d: u64): i32 {
  (a + b + c + d).as[i32]
}
fn sum-fn-struct(s: { a: u64, b: u64, c: u64, d: u64 }): i32 {
  (s.a + s.b + s.c + s.d).as[i32]
}

// nocommit: abi/ffi test some 'sum' types


fn main(): i32 {
  #static testAll();
  testAll();
  testFnPtr();
  0
}

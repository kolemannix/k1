ns zst_test;

let globalZst: {} = {}

fn testGlobal(): empty {
  assert-equals(0, types/size[type-of(globalZst)]);
  globalZst;
  assert-equals(globalZst, &globalZst.*);
}

fn testLocal(_a: empty, _b: empty, _c: empty, _d: empty): empty {
  let l = {};
  assert-equals(types/size[type-of(l)], 0);
  l
}

fn test() {
  globalZst; // empty
  &globalZst;
  &globalZst.*; // no-op yielding Value::Empty

  testLocal({}, {}, {}, {});
  staticZst();
}

fn staticZst() {
  let point = #static { x: 1, y: (#static 2): int };
  assert-equals(point.x.from-static(), 1);
}


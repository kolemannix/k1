ns zst_test;

let global-zst: {} = .{}

fn test-global(): empty {
  assert-equals(0, types/size[type-of(global-zst)]);
  global-zst;
  assert-equals(global-zst, (&global-zst).*);
}

fn test-local(_a: empty, _b: empty, _c: empty, _d: empty): empty {
  let l = .{};
  assert-equals(types/size[type-of(l)], 0);
  l
}

fn test() {
  global-zst; // empty
  &global-zst;
  (&global-zst).*; // no-op yielding Value::Empty

  test-local(.{}, .{}, .{}, .{});
  static-zst();
}

fn static-zst() {
  let point = #static .{ x = 1, y = (#static 2): int };
  assert-equals(point.x.from-static(), 1);
}


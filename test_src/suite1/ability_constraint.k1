ns ability_constraint {

  ability Num {
    fn num(self): i32
  }
  
  fn add[T](a: T, b: T): i32 where T: Num, T: show {
    a.show();
    b.show();
    a.num() + b.num()
  }
  
  impl Num for int {
    fn num(self): i32 { self.as() }
  }
  
  fn test() {
    assert(add(1, 2) == 3);
    {}
  }

}

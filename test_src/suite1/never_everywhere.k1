ns never_everywhere;

fn takesFour(_a: empty, _b: empty, _c: empty, _d: empty) {{}}
fn callArguments(): never { 
  // We're going to do stuff in call arguments that ultimately crash, and ensure that
  // they do run in order up to the 'never' typed one
  let* counter = 0;
  let incr = \() { counter <- counter.* + 1 };
  // This should get compiled to:
  // { incr(); incr(), incr(), { if i.* == 3 core/sys/exit(0) else crash("i wasnt incremented") } }
  // No 'call' is even emitted
  takesFour(
    _a = incr(),
    _b = incr(),
    _c = incr(),
    _d = { if counter.* == 3 core/sys/exit(0) else crash("counter wasnt incremented") }
  )
}
fn letRhs(): empty { let _x = crash("letRhs") }
fn assgnRhs(): never { let _x = 123; _x := crash("assgn rhs") }
// should fail to compile anyway
// fn binopLhs(): never { crash("") + 4 }
fn binopRhs(): int { 4 + crash("") }
fn unop(): never { not crash("") }
fn whileCond(): never { while crash("asdf") { {} } }
fn enumConstrPayload(): never { opt.some(crash("asdf")) }
fn getEnumPayload(): i64 { 
  let x: ?int = opt.some(crash(""));
}
fn castTarget(): i64 { crash(""): i64 }
fn inReturn(): never { 
  #static assertEquals(
    testCompile(
      return(crash("what"))
    ),
    .some("return is dead since returned expression is divergent; remove the return")
  );

  core/sys/exit(0)
}
fn inBreak(): never { 
  #static assertEquals(
    testCompile(
      loop { break(crash("inBreak")) }
    ),
    .some("break is dead since returned expression is divergent; consider removing the 'break'")
  );
  core/sys/exit(0)
}

fn test() {
  let crashyArgsError = testCompile(#static callArguments());
  assert(crashyArgsError is .none);
}

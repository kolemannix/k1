ns lambdas {

fn staticAddOne(x: int): int { x + 1 }
fn staticAddTwo(x: int): int { x + 2 }

fn captures() {
  let closedOver: int = 3;

  let add = fn(x: int) {
    let addOne = fn(y: int) y + 1;
    addOne(x) + closedOver + addOne(closedOver) + (if closedOver == 3 1 else 0);
  };

  assertEquals(add(3), 12);
}

fn captureMut() {
  let* counter = 3;

  let myInc = fn() {
    counter <- counter.* + 1;
  };

  myInc();
  myInc();
  myInc();

  assert(counter.* == 6);
}

fn closureReturn() {
  let getThree = fn(-> int) { return(3) };
  let nullary = fn() 4;
  assert(getThree() == 3);
  assert(nullary() == 4);
}

fn simpleDyn(thunk: dyn[fn() -> {}]) {
  thunk()
}

fn someFnParam1(i: int, f: some fn int -> int): int {
  f(i)
}

fn someFnParam2(i: int, f: some fn int -> int, g: some fn int -> int): int {
  f(i) + g(i)
}

fn someFnParamGen[T](t: T, f: some fn T -> T, g: some fn T -> ?T): ?T {
  t || f || g
}

fn runThings(thunks: list[dyn[fn() -> empty]]) {
  for thunk in thunks { thunk() }
}

fn thunksTest() {
  let* counter = 0;
  let thunks: list[dyn[fn() -> empty]] = [
    fn. { counter <- counter.* + 1 },
    fn. { counter <- counter.* + 1 },
    fn. { counter <- counter.* + 1 },
  ];

  runThings(thunks);
  assertEquals(counter.*, 3);
}

fn test() {

  let staticAddOneVar = staticAddOne.toRef();
  let staticResult = someFnParam2(5, staticAddOne.toRef(), staticAddOneVar);
  assertEquals(staticResult, 6 + 6);

  let lam1ResultPtr = someFnParam1(5, staticAddOne.toRef());
  assertEquals(lam1ResultPtr, 6);

  let lam1ResultDyn = someFnParam1(5, staticAddOne.toDyn());
  assertEquals(lam1ResultDyn, 6);

  let* c1 = { x: 3 };
  let c2 = 2;

  let withClosures = someFnParam2(5, fn x. x + 1 + c1.x, fn x. x + 2 + c2);
  assertEquals(withClosures, (5 + 1 + 3) + (5 + 2 + 2));

  let withGenerics = someFnParamGen(true, fn b. not b, fn b. some(b));
  assert(withGenerics == some(false));

  use list/filter; use list/map;
  let result = [1,2,3,5,6,7,8]
    || map(fn x. x + 1)
    || filter(fn x. x % 2 == 0);
  assert(result == [2, 4, 6, 8]);

  let* x = 10;
  // Coerce lambdas to lambda objects
  simpleDyn(fn. {"Thunk! {x.*}"; x <- 11 });
  assertEquals(x.*, 11);
  // Coerce function refs to lambda objects
  simpleDyn(fn. {"Thunk!"; x <- 12 });
  assertEquals(x.*, 12);

  thunksTest();

  captures();
  captureMut();
  closureReturn();
  {}
}

}

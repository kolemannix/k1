ns type_info;

use core/types/size
use core/types/stride
use core/types/align
use core/types/type-id

fn doIt(_foo: bool, _bar: u32): u32 {
  32
}

fn testSizeOf() {
  assertEquals(size[string], 16);
  assertEquals(stride[string], 16);
  assertEquals(align[string], 8);
  assertEquals(size[{ x: u64, c: u8 }], 9);
  assertEquals(stride[{ x: u64, c: u8 }], 16);
}

fn testFnTypeInfo() {
  assertEquals(type-id[doIt.return](), type-id[u32]());
  assertEquals(type-id[doIt._foo](), type-id[bool]());
  assertEquals(type-id[doIt._bar](), type-id[doIt.return]());
}

fn test() {
  testSizeOf();
  testFnTypeInfo();
}

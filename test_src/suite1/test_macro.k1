ns test_macro;

let mutable twice-counter: int = 0
let mutable repeat-counter: int = 0

fn incr(): int {
  twice-counter = twice-counter + 1
  twice-counter
}

fn incr-repeat() {
  repeat-counter = repeat-counter + 1
}

macro twice(e) {
  "$e + $e"
}

macro repeat(n: int, body) {
  let cb = code-builder/new()
  for 0.until(n) {
    cb.code(body)
    cb.writeln("")
  }
  cb.build()
}

macro debug(e) {
  #if false "println($e)" else ""
}

fn test-twice() {
  let x = twice(incr())
  assert-equals(x, 3)
  assert-equals(twice-counter, 2)
}

fn test-repeat() {
  repeat(3, incr-repeat())
  assert-equals(repeat-counter, 3)
}

fn test-debug-elided() {
  debug(crash("this must never run"))
}

fn test-code-value() {
  let c = \incr()
  assert-equals(c.chunks.len(), 1)
  let chunk = c.chunks.get(0)
  assert-equals(chunk.text, "incr()")
  assert(chunk.source != 0)
}

fn test-code-literal() {
  let a = \9 * 9
  let c: code = "let q = $a"
  assert-equals(c.text(), "let q = 9 * 9")
  assert-equals(c.chunks.len(), 2)
  assert-equals(c.chunks.get(1).text, "9 * 9")
  assert(c.chunks.get(1).source != 0)
}

fn test-code-fmt() {
  let c: code = "let w = ${}".fmt(42)
  assert-equals(c.text(), "let w = 42")
  assert-equals(c.chunks.len(), 2)
  assert-equals(c.chunks.get(0).text, "let w = ")
  assert-equals(c.chunks.get(1).source, 0)

  // No expectation nearby? Ascribe.
  let d = "let v = ${}".fmt(7): code
  assert-equals(d.text(), "let v = 7")
}

fn test-code-builder() {
  let a = \1 + 2
  let cb = code-builder/new()
  cb.write("let z = $a; z * 2")
  let built = cb.build()
  assert-equals(built.text(), "let z = 1 + 2; z * 2")
  assert-equals(built.chunks.len(), 3)
  assert-equals(built.chunks.get(1).text, "1 + 2")
}

fn test() {
  test-twice()
  test-repeat()
  test-debug-elided()
  test-code-value()
  test-code-literal()
  test-code-fmt()
  test-code-builder()

  .{}
}

ns match_references;

fn test() {
  let x = some(42);
  let x = &x;
  while x.* is :some(xx) {
    if xx == 0 break()
    else { 
      x <- some(xx - 1);
    }
  };

  let point = { x: 5, y: 2 };
  let point = &point;
  if point is { x, y: 2 }* {
    assert-equals(x.*, 5);
  };

  x <- some(5);
  while x is :some(xx)* {
    if xx.* == 0 break()
    else { 
      xx <- xx.* - 1;
    }
  };
  assert-equals(x.*, :some(0));

  use core/mem/new;
  let b: ***bool = new[**bool](new[*bool](new[bool](true)));
  if not b is true*** { crash("b was false!") };
  assert(b.*.*.* == true);

  b.*.* <- false;
  if b is true*** { crash("b was true!") };
  assert(b.*.*.* == false);

  switch b {
     true*** -> crash("b was true!"),
     false*** -> {}
  };

  switch b {
    null -> crash("b was null"),
    _ -> {}
  };

  switch b.as[ptr] {
    null -> crash("b was null as ptr"),
    _ -> {},
  };

  {}
}

ns place_test;

type Inner = { a: int, b: int }
type Outer = { name: string, inner: Inner }
type Shape = either { circle({ radius: int, filled: bool }), point }

let globalPlaceVal: int = 77

fn makeInner(): Inner {
  { a: 1, b: 2 }
}

ns for Inner {
  fn me(self: *mut Inner): *mut Inner { self }
}

// Receiver auto-address-of must resolve to the real field place, not a copy.
// Regression: the non-generic call path discarded the coerced receiver, so
// outerRef.inner.me() got the address of a stack temp (dogfood/http hit this
// as a corrupted libuv handle).
fn receiverCoercion() {
  let outer: Outer = { name: "hi", inner: { a: 11, b: 22 } };
  let outerRef = &outer;
  let innerRef = outerRef.inner.&;
  assert(outerRef.inner.me().as[ptr] == innerRef.as[ptr]);
  outerRef.inner.me().a <- 99;
  assert-equals(outer.inner.a, 99);
}

fn negativeCases(p: int, s: Inner, arr: array[int, 3]) {
  // Element address rooted at a by-value param is rejected like any param place
  let paramElemResult = testCompile(arr.get(0).&);
  assert-equals(
    paramElemResult,
    :some("Cannot take address of a function parameter; re-declare it or use a * type")
  );
  // Address of a function parameter is rejected at the place root
  let paramResult = testCompile(&p);
  assert-equals(
    paramResult,
    :some("Cannot take address of a function parameter; re-declare it or use a * type")
  );
  // ...even through a field chain rooted at the parameter
  let paramFieldResult = testCompile(&s.a);
  assert-equals(
    paramFieldResult,
    :some("Cannot take address of a function parameter; re-declare it or use a * type")
  );
  // A call result is not a place
  let rvalueResult = testCompile(&makeInner().a);
  assert-equals(
    rvalueResult,
    :some("Cannot take the address of a call; only places (variables, struct fields, array elements, sum payloads, and dereferences) have addresses")
  );
}

fn test() {
  // Address of a local
  let x = 10;
  let xRef = &x;
  assert-equals(xRef.*, 10);

  // Postfix .& is the same operation
  let xRef2 = x.&;
  assert-equals(xRef2.*, 10);

  // Address of a nested struct field, and writing through it
  let outer: Outer = { name: "hi", inner: { a: 5, b: 6 } };
  let aRef = &outer.inner.a;
  assert-equals(aRef.*, 5);
  aRef <- 42;
  assert-equals(outer.inner.a, 42);

  // Re-borrow: field address through an existing reference
  // AddressOf(FieldAccess(FieldAccess(Deref(outerRef)))) -> allowed
  let outerRef = &outer;
  let bRef = &outerRef.inner.b;
  assert-equals(bRef.*, 6);

  // Address of a global
  let gRef = &globalPlaceVal;
  assert-equals(gRef.*, 77);

  let arr: array[int, 3] = zeroed();
  arr.get(0) <- 10;
  arr.get(1) <- 20;
  let elemRef = arr.get(1).&;
  assert-equals(elemRef.*, 20);
  elemRef <- 21;
  assert-equals(arr.get(1), 21);

  // ...and through an array reference
  let arrRef = &arr;
  let elemRef2 = arrRef.get(2).&;
  elemRef2 <- 30;
  assert-equals(arr.get(2), 30);

  // Mixed aggregates: store to a struct member inside an array element
  // (place chain: field -> block -> array element -> variable)
  let points: array[Inner, 2] = zeroed();
  points.get(0).a <- 100;
  points.get(1).b <- 200;
  assert-equals(points.get(0).a, 100);
  assert-equals(points.get(0).b, 0);
  let pointBRef = points.get(1).b.&;
  pointBRef <- 201;
  assert-equals(points.get(1).b, 201);

  // Mixed aggregates: store to struct members inside a sum payload, through a
  // reference binding from a switch on the variant
  let shape: Shape = :circle({ radius: 5, filled: false });
  switch &shape {
    :circle(c)* -> {
      c.radius <- 10;
      c.filled <- true;
    },
    _ -> crash("expected a circle")
  };
  switch shape {
    :circle(c) -> {
      assert-equals(c.radius, 10);
      assert(c.filled);
    },
    _ -> crash("expected a circle")
  };

  receiverCoercion();

  negativeCases(3, { a: 1, b: 2 }, arr);
}

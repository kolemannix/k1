ns union_basic;

type u = union { a: u32, b: f32, c: i32 }

fn identity-u(u: u): u {
  u
}

fn test() {
  assert-equals(types/size[u], 4);
  assert-equals(types/align[u], 4);
  let u: u = uninit;

  require types/schema[u] is :union({ .fields })
    and fields.len() == 3
    and fields.get(0).name == "a"
    and fields.get(0).offset == 0
    and fields.get(1).name == "b"
    and fields.get(1).offset == 0
    and fields.get(2).name == "c"
    and fields.get(2).offset == 0
    else crash("");

  identity-u(u);

  {}
}

ns optionals;

deftype PointMaybeY = { x: int, y: ?int }

fn testBasics(): int {
  let p: ?PointMaybeY = :some({ x: 1, y: :some(2) });
  assert(p.!.x == 1);
  assert(p.!.y.! == 2);

  let b = :some(true): ?bool;
  if b is :some(x) {
    assert(x);
  };

  assert(opt/isSome[bool](b));
  let c: ?int = :none;
  assert(not c.isSome());

  use types/type-id;
  assert(type-id[PointMaybeY.y:some] == type-id[int]);

  0
}

deftype WeirdPoint = { x: ?int, y: int }

fn testComplex(): int {
  let my_point: WeirdPoint = { x: :some(42), y: 0 };
  if my_point.x is :some(my_x) {
    assert(my_x == 42);
  } else {
    assert(false);
  };

  let my_arr: list[?WeirdPoint] = [:some({ x: :some(42), y: 3}), :none];
  if my_arr.get(0) is :some(a) {
    assert(a.y == 3);
  };

  0
}

fn noNum(): ?int { :none }
fn someNum(): ?int { :some(100) }

fn optElseOperator() {
  let result = noNum() ? 42;
  assert(result == 42);

  let result = someNum() ? 41;
  assert(result == 100);
}

fn blanketImpls() {
  assert(some(4) == some(4));
  assert(some(2).get-value() == 2);
  assert(some(true).get-value() != false);
}

fn test() {

  testBasics();
  testComplex();
  optElseOperator();
  blanketImpls();

}

ns test_comptime;

let e: ?int = .some(42)
let n: ?int = .none

fn simpleEnum() {
  assertEquals(e.!, 42);
  assert(e != n);
  assertEquals(e, some(42));
  {}
}

let p: { x: int, y: ?int } = { x: 1, y: .some(2) }

fn simpleStruct() {
  assertEquals(p.x, 1);
  assertEquals(p.y, some(2));
}

fn test() {
  simpleEnum();
  simpleStruct();
}

ns test_globals

let foo: int = 42
let bar: int = 31

let global-int: int = 0
let mutable global-int-mut: int = 10
let static-int: int = 2

let mutable global-mut-ptr: ptr = ptr/null

let global-string: string = "imglobal"

fn test() {

   assert-equals(foo, 42)
   assert-equals(bar, 31)

   assert-equals(global-int, 0)
   assert-equals(static-int, 2)

   while global-int-mut > static-int {
     global-int-mut = global-int-mut - 1
   }
   assert(global-int-mut == 2)

   global-mut-ptr = (&global-int-mut).as[ptr]
   assert-equals(global-mut-ptr.as[*int].*, 2)
   assert((&global-int-mut).as[ptr] == global-mut-ptr)

   assert-equals(global-string.len(), 8)
   assert-equals(global-string, "imglobal")

  .{}
}

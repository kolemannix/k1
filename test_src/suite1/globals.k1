ns test_globals;

let foo: int = 42
let bar: int = 31

let globalInt: int = 0
let* globalIntRef: *mut int = 10
let staticInt: int = 2

let* globalPtr: *mut ptr = ptr/null

let globalString: string = "imglobal"

fn test() {

   assertEquals(foo, 42);
   assertEquals(bar, 31);

   assertEquals(globalInt, 0);
   assertEquals(staticInt, 2);

   while globalIntRef.* > staticInt {
     globalIntRef <- globalIntRef.* - 1;
   };
   assert(globalIntRef.* == 2);

   globalPtr <- globalIntRef.as[ptr];
   assertEquals(globalPtr.*.as[*int].*, 2);
   assert(globalIntRef.as[ptr] == globalPtr.*);

   assertEquals(globalString.len(), 8);
   assertEquals(globalString, "imglobal");

  {}
}

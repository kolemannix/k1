ns test_globals;

let foo: int = 42
let bar: int = 31

let globalInt: int = 0
let mutable globalIntMut: int = 10
let staticInt: int = 2

let mutable globalMutPtr: ptr = ptr/null

let globalString: string = "imglobal"

fn test() {

   assertEquals(foo, 42);
   assertEquals(bar, 31);

   assertEquals(globalInt, 0);
   assertEquals(staticInt, 2);

   while globalIntMut > staticInt {
     &globalIntMut <- globalIntMut - 1;
   };
   assert(globalIntMut == 2);

   &globalMutPtr <- &globalIntMut.as[ptr];
   assertEquals(globalMutPtr.as[*int].*, 2);
   assert(&globalIntMut.as[ptr] == globalMutPtr);

   assertEquals(globalString.len(), 8);
   assertEquals(globalString, "imglobal");

  {}
}

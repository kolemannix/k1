ns test_globals;

let foo: int = 42
let bar: int = 31

let globalInt: int = 0
let mutable globalIntMut: int = 10
let staticInt: int = 2

let mutable globalMutPtr: ptr = ptr/null

let globalString: string = "imglobal"

fn test() {

   assert-equals(foo, 42);
   assert-equals(bar, 31);

   assert-equals(globalInt, 0);
   assert-equals(staticInt, 2);

   while globalIntMut > staticInt {
     globalIntMut <- globalIntMut - 1;
   };
   assert(globalIntMut == 2);

   globalMutPtr <- &globalIntMut.as[ptr];
   assert-equals(globalMutPtr.as[*int].*, 2);
   assert(&globalIntMut.as[ptr] == globalMutPtr);

   assert-equals(globalString.len(), 8);
   assert-equals(globalString, "imglobal");

  {}
}

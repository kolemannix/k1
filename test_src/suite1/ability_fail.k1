ns ability_fail;
ability num {
  fn num(self: self): i32
}

deftype Tool = either True, False, Iono

fn test() {
  let p: Tool = .True;
  let result = testCompile(p.num());
  assertEquals(result, .some(
`Call to num/num with self := Tool does not work
No matching implementations found
Function type: \('self) -> i32`
  ))
}

ns iterator_tests;

use iter/find
use iter/position

fn test() {

  let firstEven = find([1,2,3,4], fn(x) x % 2 == 0);
  assert-equals(firstEven, some(2));

  let indexOfThree = position([1,2,3,4], 3);
  assert-equals(indexOfThree, some(2));

  assert(not core/iter/exists([1,2,3,5,7,9,11], fn(t) t == 0));
  assert(iter/exists([1,2,3,5,7,9,11], fn(t) t == 2));

  assert(iter/forall([1,3,5,7,9,11], fn(t) t % 2 == 1));

  assert(iter/sum([1,3,5,7,9,11]) == 36);

  {}
}

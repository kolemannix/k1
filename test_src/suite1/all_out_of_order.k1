ns all_out_of_order

impl say-hello for foo {
  fn hello(self: foo): my-string { 
    .{ s = self.name  }
  }
}

fn takes-helloer[t](t: t): my-string where t: say-hello {
  t.hello()
}

ability say-hello {
  fn hello(self): my-string {
    .{ s = "Hello" }
  }
}


fn test() {
  let foo: foo = .{ name = "Joe" }
  foo.hello()
  assert(takes-helloer(foo).s == "Joe")
}

type my-string = { s: string }

type foo = { name: string }

ns bar {
  // Type with NS used before defined
  use foo/core/nested
  fn do-it(_t: nested): nested { 
    // before called
    before()
    nested/default
  }
  // before imported (below where called)
  use secret/before
}

ns secret {
  // before defined (below where imported and called)
  fn before() { .{} }
}

ns foo {
  ns core {
    type nested = either { a, b }
    ns for nested {
      let default: nested = :a
    }
  }
}


ns meta_defns;

$ "let n: u64 = 255"
$ "let x: u64 = 256"

$ p"fn isPow2(x: u64): bool { (x - 1) || bitwise/bit-and(x) == 0 }"

$ {
  let name1 = "1";
  let name2 = "2";
  let a = "ns Secret {{ fn secret{name1}(): int {{ 42 } }\n";
  let b = "ns Secret {{ fn secret{name2}(): int {{ 43 } }\n";
  "{a}{b}"
}

$ {
  p"deftype Frob = { b: bool }"
}

$ {
  p"ability Named { fn getName(self): string }"
}

$ {
  p`impl Named for Frob {
    fn getName(self): string { if self.b "Bob" else "Joe" }
  }`
}

$ core/meta/defineSoA[{ x: u32, y: u32, z: u8 }]("Point3List")

fn test() {
  let frob: Frob = { b: false };

  assertEquals(frob.getName(), "Joe");
  assertEquals(isPow2(n), false);
  assertEquals(isPow2(x), true);
  assertEquals(Secret/secret1(), 42);
  assertEquals(Secret/secret2(), 43);

  let* ps = Point3List/empty();
  ps.push({ x: 5, y: 10, z: 15 });
  let p = ps.get(0);
  assertEquals(p.x, 5);
  assertEquals(p.y, 10);
  assertEquals(p.z, 15);

}

// Only "static, true" and "meta, true" should appear

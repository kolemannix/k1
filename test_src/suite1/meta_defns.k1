ns meta_defns;

$ "let n: u64 = 255"
$ "let x: u64 = 256"

$ p"fn is-pow2(x: u64): bool { (x - 1) || bitwise/bit-and(x) == 0 }"

$ {
  let name1 = "1";
  let name2 = "2";
  let a = "ns secret \{ fn secret{name1}(): int \{ 42 } }\n";
  let b = "ns secret \{ fn secret{name2}(): int \{ 43 } }\n";
  "{a}{b}"
}

$ {
  p"type frob = { b: bool }"
}

$ {
  p"ability named { fn get-name(self): string }"
}

$ {
  p`impl named for frob {
    fn get-name(self): string { if self.b "Bob" else "Joe" }
  }`
}

$ core/meta/define-soa[{ x: u32, y: u32, z: u8 }]("point3-list")

fn test() {
  let frob: frob = { .b = false };

  assert-equals(frob.get-name(), "Joe");
  assert-equals(is-pow2(n), false);
  assert-equals(is-pow2(x), true);
  assert-equals(secret/secret1(), 42);
  assert-equals(secret/secret2(), 43);

  let ps = point3-list/empty();
  ps.push({ .x = 5, .y = 10, .z = 15 });
  let p = ps.get(0);
  assert-equals(p.x, 5);
  assert-equals(p.y, 10);
  assert-equals(p.z, 15);

}

// Only "static, true" and "meta, true" should appear
// #if true #static { println("static, true"); {} } 
// #if false #static { println("static, false"); {} } 
// #if true ${ println("meta, true"); "let u1: empty = \{};" } 
// #if false ${ println("meta, false"); "let u2: empty = \{};" } 

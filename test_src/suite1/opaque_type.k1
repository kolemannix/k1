ns opaque_test

type named-opaque = opaque[16, 4]

fn test() {
  let _x: opaque[8, 4] = uninit
  let x2: opaque[8, 4] = zeroed()

  assert(types/type-id[named-opaque] != types/type-id[opaque[16, 4]])

  assert-equals(types/size[opaque[10, 1]], 10)
  assert-equals(types/size[opaque[128, 8]], 128)

  // we don't crash when matching on an opaque
  require x2 is _

  assert-equals(types/size[{
    x: i32, y: i32, z: opaque[128, 8]
  }], 136)

  assert-equals(types/align[opaque[10, 1]], 1)
  assert-equals(types/align[opaque[10, 16]], 16)
}

ns condcomp;


let MY_VALUE: bool = true
let MY_VALUE_NEG: bool = not MY_VALUE

fn test() {
  use core/k1;
  let a = k1/os;
  assert(k1/os == .macos);
  assert(k1/os == a);
  assertEquals(k1/test, false);

  let trip = false;
  #if MY_VALUE_NEG {
    crash("does not happen")
  } else {
    trip := true;
  };
  assert(trip);

  let comptimeCheck = #if false "foo" else "bar";
  assert(comptimeCheck == "bar");

  {}
}

ns ability_generic {

  impl g-add[rhs = i32, output = i32] for i32 {
    fn gadd(self: i32, rhs: rhs): i32 { self + rhs }
  }

  impl g-add[rhs = i64, output = i64] for i32 {
   fn gadd(self: i32, rhs: i64): i64 { self.as[i64] + rhs }
  }

  ns foob {
    type alias my-int = int

    impl g-add[rhs = my-int, output = my-int] for my-int {
      fn gadd(self: my-int, rhs: my-int): my-int { self + rhs }
    }
  }

  type generic-point[t] = { x: t, y: t }
  ability g-add[rhs, impl output] {
    fn gadd(self, rhs: rhs): output
  }
  impl[t: g-add[rhs = t, output = t] and show]
    g-add[rhs = generic-point[t], output = generic-point[t]]
    for generic-point[t] {
      fn gadd(self: generic-point[t], other: generic-point[t]): generic-point[t] {
        let new-x: t = self.x.gadd(other.x);
        //let a = self.x; let b = other.x;
        //println("generic-point.add x {a} + {b} = {new-x}");
        let new-y: t = self.y.gadd(other.y);
        //let a = self.y; let b = other.y;
        //println("generic-point.add y {a} + {b} = {new-y}");
        { .x = new-x, .y = new-y }
      }
  }

  ability from[f] { fn from(t: f): self }
  ability to[to] { fn to(self): to }

  impl[t: show] to[to = string] for t {
    fn to(self: t): string { self.show() }
  }

  impl[u, t: to[to = u]] from[f = t] for u {
    fn from(t: t): u { t.to() }
  }

  impl to[to = string] for i32 {
    fn to(self): string { show/show[i32](self) }
  }
  impl to[to = string] for i64 {
    fn to(self): string { show/show[i64](self) }
  }
  impl to[to = char] for byte {
    fn to(self: byte): char { self.as() }
  }

  fn test() {

    let _btoc: char = (101: u8).to();

    let x: i32 = 4;

    let add32 = x.gadd(10: i32);
    assert(add32 == 14);

    let add64 = x.gadd(12: i64);
    assert(add64 == 16: i64);

    // Blanket Impls
    let p: generic-point[i32] = { .x = 1, .y = 2 };

    let added: generic-point[i32] = p.gadd(p);
    assert-equals(added.x, 1i32 + 1);
    assert-equals(added.y, 2i32 + 2);

    assert-equals((3: i32).to(): string, "3");
    assert-equals(from/from(3: i32): string, "3");
  }

}

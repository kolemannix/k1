ns any_test;

use types/any
use types/type-schema
use types/type-id
use types/make-any

fn kindOfAny(any: any): string {
  typeVariantName(any.type-id)
}

fn typeVariantName(type-id: u64): string {
  let schema = types/type-schema(type-id);
  let schemaSchema = types/type-schema(type-id[type-schema]);
  require schemaSchema is .either(e) else { crash("type-schema of type-schema should be a sum") };
  let variant = core/iter/find(e.variants, fn v.
    if v.tag is .u8(t) and t == schema.tag true else false
  ).!;
  variant.name
}

fn test() {
  let* i: *int = 10;
  let intPtr = make-any(i);
  let* s = { x: 1, y: 100 };
  let structPtr = make-any(s);
  assertEquals(kindOfAny(intPtr), "int");
  assertEquals(kindOfAny(structPtr), "struct");
}

ns type_schema {
  deftype Point3[t] = {
    x: t, y: t, z: t
  }

  use types/schema
  use types/type-id
  use types/type-id-schema

  fn printStructShape[T](): string {
    let id = type-id[T];
    require schema[T] is :struct({ fields }) else { return("") };
    let* sb = StringBuilder/new();
    let name = types/type-id-name(id);
    sb.string("Struct {name} {{\n");
    for field in fields {
      writelnf(sb, "  {field.name}: {types/type-id-name(field.type-id)}", );
    };
    sb.string("}");
    sb.build()
  }

  fn test() {

    assert(schema[u8]   is :int(:u8));
    assert(schema[u16]  is :int(:u16));
    assert(schema[u32]  is :int(:u32));
    assert(schema[u64]  is :int(:u64));
    assert(schema[i8]   is :int(:i8));
    assert(schema[i16]  is :int(:i16));
    assert(schema[i32]  is :int(:i32));
    assert(schema[i64]  is :int(:i64));
    let pointByteSchema = schema[Point3[u8]];
    require pointByteSchema is :struct({ fields }) else crash("");
    assertEquals(fields.len(), 3);
    require schema[*i32]
      is :reference({ mutable: false, inner-type-id })
      and inner-type-id == type-id[i32] else crash("");
    assert(schema[*mut i32] is :reference({ mutable: true }));
    assertEquals(
      schema[**bool].as-reference().!.inner-type-id,
      type-id[*bool]
    );

    assert(schema[either { Yes }] is :enum(_));

    require schema[either { Yes, No, MaybeSo(string) }]
      is :either({ variants, payload-offset })
      and payload-offset == 8
      and variants.len() == 3
      and variants.get(0).name == "Yes"
      and variants.get(1).name == "No"
      and variants.get(2).name == "MaybeSo"
      and variants.get(2).payload is :some({ type-id })
      and type-id == type-id[string]
      else crash("");

    require schema[either { Yes(int) }:Yes ]
      is :int(:i64)
      else crash("");

    assert(schema[array[i32, 10]] is :array(_));
    require schema[array[string, 5]]
      is :array({ element-type-id, size })
      and element-type-id == type-id[string]
      and size == :some(5)
      else crash("");

    assertEquals(printStructShape[Point3[u8]], p"Struct Point3[u8] {\n  x: u8\n  y: u8\n  z: u8\n}");

    let isZeroPtr: *fn(int) -> bool = isZero;
    require schema[type-of(isZeroPtr)]
      is :function-pointer({ function-type-id }) else crash("");

    require type-id-schema(function-type-id)
      is :function({ params, return-type-id }) else crash("");

    assert(type-id-schema(return-type-id) is :bool);
    assertEquals(params.get(0).name, "x");
    assert(type-id-schema(params.get(0).type-id) is :int(_));

    {}
  }

  fn isZero(x: int): bool { x == 0 }
}


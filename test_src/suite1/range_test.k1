ns range_test

fn test-basic-iteration() {
  let iter = 0.until(5).iterator()

  assert(iter.next().! == 0)
  assert(iter.next().! == 1)
  assert(iter.next().! == 2)
  assert(iter.next().! == 3)
  assert(iter.next().! == 4)
  assert(iter.next().is-none())
}

fn test-empty-range() {
  let iter = 0.until(0).iterator()
  assert(iter.next().is-none())

  // start > end is empty, not an error
  let backwards = (5: int).until(2).iterator()
  assert(backwards.next().is-none())
}

fn test-negative-range() {
  let iter = (-3: int).until(2).iterator()

  assert(iter.next().! == -3)
  assert(iter.next().! == -2)
  assert(iter.next().! == -1)
  assert(iter.next().! == 0)
  assert(iter.next().! == 1)
  assert(iter.next().is-none())
}

fn test-for-loop() {
  let sum = 0
  for i in 0.until(5) {
    sum = sum + i
  }
  assert(sum == 10)

  let count = 0
  for 3.until(6) {
    count = count + it
  }
  assert(count == 12)
}

fn test-typed-ranges() {
  let byte-count = 0
  for b in (250: u8).until(255) {
    byte-count = byte-count + 1
  }
  assert(byte-count == 5)

  let float-sum: f64 = 0.0
  for f in 0.5.until(3.0) {
    float-sum = float-sum + f
  }
  // 0.5 + 1.5 + 2.5
  assert(float-sum == 4.5)
}

fn test-nth() {
  let iter = 0.until(10).iterator()

  assert(iter.nth(3).! == 3) // Skip to 4th element
  assert(iter.next().! == 4) // Next should be 4

  assert(iter.nth(4).! == 9) // Skip 4 more to get to 9
  assert(iter.next().is-none())

  assert(iter.nth(1).is-none()) // Try to skip past end
}

fn test-advance-by() {
  let iter = 0.until(5).iterator()

  iter.advance-by(2)
  assert(iter.next().! == 2)

  iter.advance-by(1)
  assert(iter.next().! == 4)

  // Advancing past the end is harmless
  iter.advance-by(10)
  assert(iter.next().is-none())
}

fn test() {
  test-basic-iteration()
  test-empty-range()
  test-negative-range()
  test-for-loop()
  test-typed-ranges()
  test-nth()
  test-advance-by()
}

ns format-test

fn test() {
  let world = "Budapest"
  let get-world = fn. world

  // string-builder implements `writer`
  let w = string-builder/new()

  // If you have a buffer already, or any writer at all, you can 'write' to it formatted
  w.write("hello $world -- ")
  w.write("hello $world ${}", 42)
  assert-equals(w.build-tmp(), "hello Budapest -- hello Budapest 42")
  assert-equals("true", "${}".fmt(true))
  assert-equals("-3.140000", "${}".fmt(-3.14))
  assert-equals("-3", "${}".fmt(-3i8))

  assert(test-compile("${}".fmt(1, 1)).is-some())
  assert(test-compile("$missing".fmt(.{x =1})).is-some())
  // this works now because { nested: "asdf" } implements print. hah!
  assert(test-compile("$x".fmt(.{x = .{ nested = "asdf" }})).is-none())

  // Or take a string with holes and _format_ it with these values
  let s = "hello ${get-world()} ${yyyy}-${mm}-$dd".fmt(.{yyyy =2021,mm =10,dd =3})
  // TODO left pad, get it from npm!
  assert-equals(s, "hello Budapest 2021-10-3")
}

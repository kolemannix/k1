ns ability_complex;

type pair[PA, PB] = { a: *PA, b: ?PB }
ability as-pair[AA, BB] {
  fn get-a(self): *AA
  fn get-b(self): ?BB
}

impl[a, b] as-pair[AA = a, BB = b] for pair[a, b] {
  fn get-a(self: pair[a, b]): *a { self.a }
  fn get-b(self: pair[a, b]): ?b { self.b }
}

// blanket impl that insanely swaps the pair for you
impl[a, b] as-pair[AA = a, BB = b] for pair[b, a] {
  fn get-a(self: pair[b, a]): *a { mem/new(self.b.!) }
  fn get-b(self: pair[b, a]): ?b { some(self.a.*) }
}

fn unwrap-b[
  x,
  y,
  t: as-pair[AA=x, BB=y] and as-pair[AA=y, BB=x]
](t: t): y {
  // Ability call resolution picks the implementation that results in the call working!
  let y: ?y = t.get-b();
  y.!
}

fn get-nothin[a, b, t: as-pair[AA=a, BB=b]](_t: t) {
  {}
}

fn test() {
  // Phase 1
  let my-pair: pair[int, bool] = { .a = mem/new(10), .b = some(true) };
  get-nothin(_t = my-pair);
  let b = unwrap-b[int, bool, pair[int, bool]](my-pair);
  assert(b);
  let i = unwrap-b[bool, int, pair[int, bool]](my-pair);
  assert-equals(i, 10);

  {}
}

ns struct_test

type point = { x: int, y: int, z: int, is-good: bool }
fn basic-struct(): int {
  let zero: point = .{
    x = 0, y = 298, z = 42, is-good = true
  }
  assert(zero.x == 0)
  assert(zero.z == 42)
  assert(zero.is-good)
  assert(zero.y == 298)
  0
}

type foo = { x: int, y: bool }
ns for foo {
  fn get-value(self: foo): int { self.x }
  fn set-value(self: *mut foo, x: int) { self.x = x; }
  fn new(x: int): foo { .{ x = x, y = false } }
}

fn struct-arg-mut() {
  let x = foo/new(42)
  let x = &x
  assert(x.x == 42)
  assert(x.get-value() == 42)
  x.set-value(41)
  assert(x.get-value() == 41)
  assert(not x.y)
}

impl equals for { a: int } {
  fn equals(self: { a: int }, other: { a: int }): bool {
    self.a == other.a
  }
}
fn eq-anon() {
  let foo = .{ a = 3 }
  let bar = .{ a = 4 }
  assert(foo != bar)
  assert(.{a = 4} == bar)
}


type block = {
  position: { x: int, y: int, width: int, height: int },
  text: int
}

fn block_area(b: block): int { b.position.width * b.position.height }

fn struct-nested() {
  let width = 50
  let b: block = .{
    position = .{ x = 1, y = 1, width, height = 50 },
    text = 42
  }
  let area: int = block_area(b)
  assert(area == 2500)
  let area2: int = block_area(.{ position = .{ x = 1, y = 1, width = 50, height = 50 }, text = 42 })
  assert(area2 == 2500)
}

fn with-fields() {
  let breaker = false; let breaker = &breaker

  let make-struct = fn. { if breaker.* crash(""); breaker.* = true; .{ a = 1, b = true, c = "hello", d = .{ inside = 0 } } }
  let s: { a: int, b: bool, c: string, d: { inside: int } } = make-struct().with(.{ a = 4, b = false, d = .{ inside = 1 }})

  assert-equals(s.a, 4)
  assert-equals(s.b, false)
  assert-equals(s.c, "hello")
  assert-equals(s.d.inside, 1)
}

fn auto-equals() {
  let a: { x: int, y: f32 } = .{ x = 10, y = 10.0 }
  let b: { x: int, y: f32 } = .{ x = 20, y = 20.0 }
  let c: { x: int, y: f32 } = .{ x = 10, y = 10.0 }
  assert(a != b)
  assert(a == c)
  core/assert-not-equals(a, b)
  assert-equals(a, c)

  assert-equals(a.show(), p"{ x: 10, y: 10.000000 }")
}

fn test() {
  let _ = basic-struct()
  struct-arg-mut()
  eq-anon()
  struct-nested()
  with-fields()
  auto-equals()
}

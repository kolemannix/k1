ns struct_test;

deftype Point = { x: int, y: int, z: int, isGood: bool }
fn basicStruct(): int {
  let zero: Point = {
    x: 0, y: 298, z: 42, isGood: true
  };
  assert(zero.x == 0);
  assert(zero.z == 42);
  assert(zero.isGood);
  assert(zero.y == 298);
  0
}

deftype Foo = { x: int, y: bool }
ns Foo {
  fn getValue(self: Foo): int { self.x }
  fn setValue(self: *mut Foo, x: int) { self.x* <- x; }
  fn new(x: int): Foo { { x: x, y: false } }
}

fn structArgMut() {
  let* x = Foo/new(42);
  assert(x.x == 42);
  assert(x.getValue() == 42);
  x.setValue(41);
  assert(x.getValue() == 41);
  assert(not x.y);
}

impl equals for { a: int } {
  fn equals(self: { a: int }, other: { a: int }): bool {
    self.a == other.a
  }
}
fn eqAnon() {
  let foo = { a: 3 };
  let bar = { a: 4 };
  assert(foo != bar);
  assert({a: 4} == bar);
}


deftype Block = {
  position: { x: int, y: int, width: int, height: int },
  text: int
}

fn block_area(b: Block): int { b.position.width * b.position.height }

fn structNested() {
  let width = 50;
  let b: Block = {
    position: { x: 1, y: 1, width, height: 50 },
    text: 42
  };
  let area: int = block_area(b);
  assert(area == 2500);
  let area2: int = block_area({ position: { x: 1, y: 1, width: 50, height: 50 }, text: 42 });
  assert(area2 == 2500);
}

fn withFields() {
  let breaker = false; let breaker = &breaker;

  let makeStruct = fn. { if breaker.* crash(""); breaker <- true; { a: 1, b: true, c: "hello", d: { inside: 0 } } };
  let s: { a: int, b: bool, c: string, d: { inside: int } } = makeStruct().with({ a: 4, b: false, d: { inside: 1 }});

  assertEquals(s.a, 4);
  assertEquals(s.b, false);
  assertEquals(s.c, "hello");
  assertEquals(s.d.inside, 1);
}

fn test() {
  basicStruct();
  structArgMut();
  eqAnon();
  structNested();
  withFields();
}

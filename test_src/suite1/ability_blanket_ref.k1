ns ability_blanket_ref;

// Repro for the blanket ref-self gap: `speak` is implemented for *thing, not
// thing. `greet` is provided by a blanket impl whose param is bounded by
// `speak`, and `cheer` is a default method of `greet`. Resolving either for a
// by-value thing must retry the bound against *thing, the same way the
// top-level impl search does. This mirrors string-builder/code-writer, where
// writer is implemented for *string-builder and impl-print is a default
// method of code-writer's blanket impl (bitfield.k1 needed `(&code)`).

ability speak {
  fn speak(self): string
}

type thing = { x: i32 }

impl speak for *thing {
  fn speak(self): string { "ref{self.x}" }
}

ability greet {
  fn greet(self): string

  fn cheer(self): string {
    "{self.greet()}!"
  }
}

impl[t: speak] greet for t {
  fn greet(self): string { "hi {self.speak()}" }
}

fn test() {
  let th: thing = { .x = 1 };
  // By-value calls first: an earlier (&th) call would instantiate and cache
  // the blanket impl for *thing, letting the ref-self retry find it and
  // masking the bug this test guards against.
  assert-equals(th.greet(), "hi ref1");
  assert-equals(th.cheer(), "hi ref1!");
  assert-equals((&th).greet(), "hi ref1");
  assert-equals((&th).cheer(), "hi ref1!");
}

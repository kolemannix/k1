ns array_test;

deftype Thing = {
  data: array[u8, 1024],
  data2: array[u64, 1024],
}

fn testLiterals() {
  let* array: *mut array[bool, 3] = [false, true, true];
  let buffer: buffer[bool] = [false, true, true];
  let list: list[bool] = [false, true, true];
  assertEquals(array.as-buffer(), buffer);
  assertEquals(list.asBuffer(), buffer);
}

fn testFilled() {
  let context alloc: mem/alloc-mode = .arena;
  let buffer: buffer[u8] = buffer/filledIn(size = 64, value = 3);
  let array: *array[u8, 64] = array/filled-in(3, 64);
  let list: list[u8] = list/filledIn(size = 64, value = 3);
  assertEquals(buffer.len, 64);
  assertEquals(array.len(), 64);
  assertEquals(list.len, 64);
  for buffer {
    assertEquals(buffer.get(itIndex), 3);
    assertEquals(list.get(itIndex), 3);
    assertEquals(array.get(itIndex), 3);
  }
}

fn testArray() {
  let context alloc: mem/alloc-mode = .arena;
  let ls: list[u8] = list/filledIn(size = 10, value = 3);

  let a: *mut array[u8, 10] = list/copyToArray(ls, 10);
  for core/IntRange/upTo(a.len()) {
    if it % 2 == 0 { a.get-ref(it) <- 1 };
  };
  for core/IntRange/upTo(a.len()) {
    if it % 2 == 0 {
      assertEquals(a.get(it), 1);
    } else {
      assertEquals(a.get(it), 3);
    }
  };
  for a {
    if itIndex % 2 == 0 {
      assertEquals(it, 1);
    } else {
      assertEquals(it, 3);
    }
  }

}

fn test() {
  assertEquals(types/size-of[Thing](), 9216);

  testArray();

  testLiterals();
  testFilled();

  let* array: *mut array[f32, 10] = mem/zeroed();
  assert(testCompile(array.get(11)) is .some(_));
  array.set(0, 3.14);
  let buf = buffer/wrapArray(array);
  assert(buf.get(0) == array.get(0));
  assertEquals(buf.get(0), array.get(0));

  {}
}

ns ability_default_fns;

let mutable I32_SPEC_COUNTER: int = 0

ability Increment {
  fn inc(self): self
  fn incTwice(self): self {
    // Testing scope bindings
    let me: self = self;
    let again: self = me;
    again.inc().inc()
  }
}
impl Increment for i32 {
  fn inc(self): self { self + 1 }
  fn incTwice(self): i32 {
    I32_SPEC_COUNTER <- I32_SPEC_COUNTER + 1;
    // Testing scope bindings
    let me: self = self;
    let again: i32 = me;
    again + 2
  }
}

impl Increment for u32 {
  fn inc(self): self { self + 1 }
}

ability IncrFour {
  fn incFour(self): self
  fn incEight(self): self {
    self.incFour().incFour()
  }
}
impl[T: Increment] IncrFour for T {
  fn incFour(self): self {
    self.incTwice().inc().inc()
  }
}


fn test() {
  let i: i32 = 554;
  assert-equals(i.inc(), 555);
  assert-equals(i.incTwice(), 556);
  assert-equals(i.incTwice().incTwice(), 558);
  assert-equals(i.incFour(), 558);
  assert-equals(i.incEight(), 562);

  let u: u32 = 0;
  assert-equals(u.incTwice(), 2);

  // Ensures that our specialized implementation is used over the default
  assert-equals(I32_SPEC_COUNTER, 6);
  
  {}
}

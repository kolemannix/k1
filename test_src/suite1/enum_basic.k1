ns enum_basic;

fn enumNoPayload() {
  let v: either { yes, no } = :no;
  if v is :no {} else crash("");
  v := :yes;
  if v is :yes {} else crash("");
}

deftype enum-abc = either(u8) { a, b, c }
impl print for enum-abc {
  fn printTo[w: writer](self, w) { switch self { 
    :a -> w.write-char('a'),
    :b -> w.write-char('b'),
    :c -> w.write-char('c'),
  } }
}
fn enumTest() {
  let a: enum-abc = :a;
  let b: enum-abc = :b;
  let c: enum-abc = :c;
  assertEquals(a.value, 0);
  assertEquals(b.value, 1);
  assertEquals(c.value, 2);
  assertEquals(a, enum-abc:a);
  assertEquals(b, enum-abc:b);
  assertEquals(c, enum-abc:c);

  assertEquals[string](a.enum-name(), "a");
  assertEquals[string](b.enum-name(), "b");
  assertEquals[string](c.enum-name(), "c");

  assertEquals(getEnumValue(c), 2);
  assertEquals(getEnumValue(b), 1);
  assertEquals(c, c);
  assertEquals(b, b);
  core/assertNotEquals(c, b);
}

fn getEnumValue[i, e: types/enum[v = i]](e: e): i {
  e.enum-value()
}

deftype custom-enum-tags = either { a = 10, b = 11, c = 12 }
fn custom-tags-test() {
  assertEquals(custom-enum-tags:a.value, 10);
  assertEquals(custom-enum-tags:b.value, 11);
  assertEquals(custom-enum-tags:c.value, 12);
}

fn test() {
  custom-tags-test();
  enumNoPayload();
  enumTest();
}


ns assign;

fn assign-var() {
  let count = 0;
  count := 1;
  assert(count == 1);
  count := 2;
  assert(count == 2);
}

fn assign-var-ref() {
  let count = 0;
  &count <- 1;
  assert(count == 1);
  &count <- 2;
  assert(count == 2);
}

fn complex-references() {
  let struct-ref = { x: 42 };
  let struct-ref = &struct-ref;

  let x-value: int = struct-ref.x;
  let x-ref: *mut int = &struct-ref.x;

  assert(x-ref.* == x-value);
  assert(struct-ref.*.x == struct-ref.x);

  x-ref <- -10;

  assert(x-ref.* == -10);

  struct-ref.x <- 42;
  assert(x-ref.* == 42);

  let either-ref: either { yes(int), no } = :yes(3);
  let either-ref = &either-ref;

  let yes-ref: *(type-of(either-ref).value:yes) = either-ref.as-yes().!;

  assert(yes-ref.* == 3);
  let yes-value: int = either-ref.as-yes().!;
  assert(yes-value == 3);

  either-ref.as-yes().! <- -3;

  assert(yes-ref.* == -3);
  assert(either-ref.as-yes().!.* == -3);

  let inner-struct-ref = { x: 42 };
  let inner-struct-ref = &inner-struct-ref;
  let struct-opt-ref: ?*{ x: int } = :some(inner-struct-ref);

  if struct-opt-ref is :some(x) {
    assert(x.x == 42);
    x.x <- 43;
    assert(x.x == 43);
  } else {
    crash("None")
  };

  {}
}

fn test() {
  assign-var();
  assign-var-ref();
  complex-references();
}

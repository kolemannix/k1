ns assign;

fn assignVar() {
  let count = 0;
  count := 1;
  assert(count == 1);
  count := 2;
  assert(count == 2);
}

fn assignVarRef() {
  let count = 0;
  &count <- 1;
  assert(count == 1);
  &count <- 2;
  assert(count == 2);
}

fn complexReferences() {
  let structRef = { x: 42 };
  let structRef = &structRef;

  let xValue: int = structRef.x;
  let xRef: *mut int = structRef.x*;

  assert(xRef.* == xValue);
  assert(structRef.*.x == structRef.x);

  xRef <- -10;

  assert(xRef.* == -10);

  structRef.x* <- 42;
  assert(xRef.* == 42);

  let eitherRef: either { yes(int), no } = :yes(3);
  let eitherRef = &eitherRef;

  let yesRef: *(type-of(eitherRef).value:yes) = eitherRef.as-yes().!;

  assert(yesRef.* == 3);
  let yesValue: int = eitherRef.as-yes().!;
  assert(yesValue == 3);

  eitherRef.as-yes().! <- -3;

  assert(yesRef.* == -3);
  assert(eitherRef.as-yes().!.* == -3);

  let innerStructRef = { x: 42 };
  let innerStructRef = &innerStructRef;
  let structOptRef: ?*{ x: int } = :some(innerStructRef);

  if structOptRef is :some(x) {
    assert(x.x == 42);
    x.x* <- 43;
    assert(x.x == 43);
  } else {
    crash("None")
  };

  {}
}

fn test() {
  assignVar();
  assignVarRef();
  complexReferences();
}

ns structural;

// Nominal
type handle = { index: size }
type handle2 = { index: size }

// Structural, just an alias
type alias handle3 = { index: size }

fn takes-structural(_s: { index: size}) { .{} }

fn get-nominal(_h: handle): string { "mock" }

fn test() {
  let handle-anon = .{ index = 10 };

  let h1 = .{ index = 10 }: handle;
  let h2: handle2 = .{ index = 10 };

  takes-structural(handle-anon);
  assert(test-compile(takes-structural(h2)).is-none());


  //:ok; structural type 'promoted' to nominal at creation time
  get-nominal(.{ index = 10 });

  // not ok; get takes `handle` nominally; h is anonymous.
  assert(test-compile(get-nominal(handle-anon)).is-some());

  //:ok; correct nominal type
  get-nominal(h1);

  // Not ok; different nominal types!
  assert(test-compile(get(h2)).is-some());
}

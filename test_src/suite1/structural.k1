ns structural;

// Nominal
type handle = { index: size }
type handle2 = { index: size }

// Structural, just an alias
type alias handle3 = { index: size }

fn takes-structural(_s: { index: size}) { {} }

fn get(_h: handle): string { "mock" }

fn test() {
  let h = { index: 10 };

  let h1 = { index: 10 }: handle;
  let h2: handle2 = { index: 10 };

  takes-structural(h);
  assert(testCompile(takes-structural(h2)).is-none());


  //:ok; structural type 'promoted' to nominal
  get({ index: 10 });

  // error, h is declared as structural
  assert(testCompile(get(h)).is-some());

  //:ok; correct nominal type
  get(h1);

  // Not ok; different nominal types!
  assert(testCompile(get(h2)).is-some());
}

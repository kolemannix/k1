ns inference;

fn combine[T](a: T, _b: T): T { a }
fn combine3[T](a: T, b: T, c: { one: T, two: T }): T { a }
fn getOrElse[T](a: opt[T], b: T): T { if a is :some(a) a else b }
fn some[U](value: U): opt[U] { opt:some[U](value) }

fn get[UU](value: opt[UU]): UU { if value is :some(u) u else core/sys/exit(1) }
fn identity[T](value: T): T { value }

fn identityNested[T](t: T): T {
  identity(t)
}

fn occursCheckTest[T](x: T): T {
  assert(
    testCompile( combine(x, some(x)) ) is :some(_)
  );
  x
}

fn test() {

  let x = identity(identity(11));
  assert(x == 11);
  let x = identity(12);
  assert(x == 12);

  identity(identity([])): list[bool];

  assert(identityNested(4) == 4);
  assert(identityNested(true));
  assert(identityNested({ value: 42 }).value == 42);

  identity(true): bool;
  identity(true);
  identity(true): bool;
  identity(identity(12));
  some(identity(13));

  get(some(10)): u32;
  combine(identity(4000), get(some(5000))): u32;
  combine(identity(8000), identity(get(some(9000)))): u32;

  assertEquals(getOrElse(some(1000), -1), 1000);

  occursCheckTest(42);

  combine(opt:some(4), some(23));
  combine(opt:some(4), some(23)): opt[u32];

  let* x = opt:some(42);

  let withNever = testCompile(
    combine3(x.*, core/sys/exit(1), { one: some(-1), two: some(3), })
  );
  assertEquals(withNever, :none);

  {}
}

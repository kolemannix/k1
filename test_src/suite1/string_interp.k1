ns string_interp_test

impl print for { name: string, weight: int } {
  fn print-to[w: writer](self, w) {
    w.string(self.name)
    w.string(": ")
    self.weight.print-to(w)
    .{}
  }
}

fn test-raw-strings() {
  let s1 = `Hello,

  "world"`
  assert-equals(s1, "Hello,\n\n  \"world\"")
}

fn test-dollar-rules() {
  let wide-world = "kebab"
  assert-equals("a $wide-world!", "a kebab!")

  // Trailing hyphen ends a bare ident when nothing identifier-ish follows
  let yyyy = 2026
  let mm = 6
  assert-equals("$yyyy-$mm", "2026-6")
  assert-equals("${yyyy}-th", "2026-th")

  // $ before a non-ident-start char is literal; \$ is always literal
  assert-equals("$5.99 costs 100$", "$5.99 costs 100$")
  assert-equals("\$yyyy is ${yyyy}", "\$yyyy is 2026")

  // Braces are plain characters
  let x = 1
  assert-equals("{ x: $x }", `{ x: 1 }`)
}

fn test() {
  let user = .{ name = "Bob", weight = 199 }
  assert-equals("Hello, '$user'!", "Hello, 'Bob: 199'!")

  let p = .{ outer = .{ inner = true } }
  assert-equals("${not p.outer.inner}", "false")

  let with-braces = "${42.show()} + ${20} = ${(.{ value = 62}.value)}"
  assert-equals(with-braces, "42 + 20 = 62")

  let nested = "${"String has ${10 + 10} in"} it"
  assert-equals(nested, "String has 20 in it")

  test-dollar-rules()
  test-raw-strings()
}

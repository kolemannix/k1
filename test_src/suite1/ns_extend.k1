ns ns_extend;

ns foo {
  type baz = { b: int }
  ns for baz {
    fn get(self: baz): int { self.b }
  }
}

ns foo {
  ns for baz {
    fn get2(self: baz): int { self.b }
  }
}


fn test() {
  let baz = { b: 32 }: foo/baz;
  assert(foo/baz/get(baz) + foo/baz/get2(baz) == 64);
  assert(baz.get() + baz.get2() == 64);
}

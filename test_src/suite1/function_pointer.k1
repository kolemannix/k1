ns function_pointer;

fn staticAddOne(x: int): int { x + 1 }
fn staticAddTwo(x: int): int { x + 2 }

type has-fn = { myfn: *fn(x: int) -> int }

fn test() {
  assert(staticAddOne.as[ptr] != staticAddTwo.as[ptr]);
  let someAddFn: *fn(int) -> int = staticAddOne;
  let _someAddFn2: *fn(x: int) -> int = staticAddOne;
  let x = someAddFn(10);
  assert-equals(x, 11);
  someAddFn := staticAddTwo;
  let y = someAddFn(20);
  assert-equals(y, 22);

  let null-callback: *fn(int) -> int = ptr/null.as();
  let null-callback-ptr: ptr = null-callback.as[ptr];
  assert-equals(null-callback-ptr, ptr/null);

  let x = staticAddOne;
  let has-fn: has-fn = { myfn: x };
  let has-fn: has-fn = { myfn: staticAddOne };

  assertEquals((has-fn.myfn)(4), 5);
  assert(testCompile( (has-fn.myfn)() ) is :some(_));
  assert(testCompile( (has-fn.myfn)(4)() ) is :some(_));

  {}
}

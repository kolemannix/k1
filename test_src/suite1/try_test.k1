ns try_test

type alias error = string

type foo = {
  a: bool
}

fn can-fail-int(): result[int, error] { :ok 42 }
fn can-fail-bool(): result[bool, error] { :ok false }

impl try[t = int, e = error] for foo {
  fn error(_e: e): self   { .{ a = false } }
  fn value(_t: t): self { .{ a = true  } }

  fn is-ok(self): bool { self.a }
  fn get-value(_self: self): t  { 3 }
  fn get-error(_self: self): e { "FooError" }
}

fn fails(): result[bool, error] {
  let value: result[int, error] = :err "woops"
  let i = value.try
  :ok(i % 2 == 0)
}

fn run(): result[i32, error] {
  let result: int = can-fail-int().try
  assert(result == 42)
  let result: int = (.{ a = true }: foo).try
  assert(result == 3)

  let c = fn(-> result[bool, error]) {
    let i = fails().try
    :ok(not i)
  }
  let res = c()
  assert(res is :err "woops")

  :ok 0
}

fn test() {
  assert(run().is-ok())
}

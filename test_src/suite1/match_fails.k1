ns match_fails;

deftype Foo = { x: int, y: ?bool }
fn useless() {
  let foo: Foo = { x: 1, y: .none };
  let result = testCompile(switch foo {
    { x, y: .some(true) } -> x,
    { x, y: .some(false) } -> x,
    { x, y: .some(false) } -> x,
    { x, y: .none } -> x + 2
  });
  assert(result is .some(_));
}

deftype Blub = { x: int, y: ?bool }
fn unhandled() {
  let blub: Blub = { x: 1, y: .none };
  let result = testCompile(switch blub {
    { x, y: .some(true) } -> x,
    { x, y: .none } -> x + 2
  });
  assert(result is .some(_));
}

fn test() {
  useless();
  unhandled();
}

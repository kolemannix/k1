ns static_parameter;

fn add-static[i: static int](x: int): int {
  let i: int = core/meta/static-type-to-value[_, i]();
  i + x
}

fn test() {
  let THREE: static int = 3;
  let result = add-static[type-of(THREE)](3);
  let result2 = add-static[3](3);
  assert-equals(result, 3 + 3);
  assert-equals(result2, 3 + 3);

  let result3 = add-static[5](3);
  assert-equals(result3, 8);

  {}
}

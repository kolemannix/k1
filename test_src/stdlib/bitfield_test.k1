// FIXME: Cannot 'use' functions for metaprogramming since they get deferred
use std/bitfield/b1 use std/bitfield/bn
$std/bitfield/define[u16]("flags-auto", [b1("shielded"), b1("cloaked"), b1("damaged"), { name: "sector-id", bits: 5 }, bn("foo", 8)])

fn test-bitfield() {
  let y: flags-auto = { bits: 0b1111_0000_1000_1101 };
  let x: flags-auto = flags-auto/zero.set-shielded(true).set-damaged(true).set-sector-id(17).set-foo(0b1111_0000);
  assert-equals(y.get-shielded(), x.get-shielded());
  assert-equals(y.get-cloaked(), x.get-cloaked());
  assert-equals(y.get-damaged(), x.get-damaged());
  assert-equals(y.get-sector-id(), x.get-sector-id());
}

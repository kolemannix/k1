// FIXME: Cannot 'use' functions for metaprogramming since they get deferred
use std/bitfield/b1 use std/bitfield/bn
$std/bitfield/define[u16]("FlagsAuto", [b1("shielded"), b1("cloaked"), b1("damaged"), { name: "sectorId", bits: 5 }, bn("foo", 8)])

fn testBitfield() {
  let y: FlagsAuto = { bits: 0b1111_0000_1000_1101 };
  let x: FlagsAuto = FlagsAuto/zero.setShielded(true).setDamaged(true).setSectorId(17).setFoo(0b1111_0000);
  assert-equals(y.getShielded(), x.getShielded());
  assert-equals(y.getCloaked(), x.getCloaked());
  assert-equals(y.getDamaged(), x.getDamaged());
  assert-equals(y.getSectorId(), x.getSectorId());
}

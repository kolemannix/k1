ns hash_test;

use std/HashMap

fn testBasic() {
  let myMap = HashMap/new[int]();
  myMap.insert("a", 10);
  myMap.insert("b", 11);
  myMap.insert("c", 12);
  assert-equals(myMap.get("a"), :some(10));
  assert-equals(myMap.get("b"), :some(11));
  assert-equals(myMap.get("c"), :some(12));
  myMap.remove("a");
  assert-equals(myMap.get("a"), :none);
  assert-equals(myMap.get("b"), :some(11));
  myMap.insert("a", 20);
  assert-equals(myMap.get("a"), :some(20));
  myMap.insert("b", 21);
  assert-equals(myMap.get("b"), :some(21));
}

fn testResize(size: int) {
  let myMap = HashMap/new[int]();
  let i = 0;
  while i < size {
    myMap.insert(i.show(), i);
    if i % 5 == 0 {
      myMap.remove(i.show())
    };
    i := i + 1
  };
  i := 0;
  // myMap.dump();
  while i < size {
    let result = myMap.get(i.show());
    if i % 5 == 0 {
      assert-msg("{i} should be empty", result is :none);
    } else {
      if result is :some(v) { assert-equals(v, i) } else { crash("Missing value {i}") }
    };
    i := i + 1
  };
  // myMap.dump();
}

fn test() {
  testBasic();
  testResize(100);
}

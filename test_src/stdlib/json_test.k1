ns json_test;
use std/json/json
use std/json

fn test-basic-enum() {
  let size = core/types/size[json]();
  let align = core/types/align[json]();
  assert-equals(size, 32);
  assert-equals(align, 8);

  let obj: json = :str("hello");
  let null: json = :null;
  assert(obj is :str("hello"));
  assert(null is :null);

  let obj2: json = :array([:str("hello"), :number(123.0)]);
  assert(obj2.as-array().!.get(0) is :str("hello"));
  assert(obj2.as-array().!.get(1) is :number(123.0));
}

fn test-parsing() {
  test-parse(`null`      , fn j. j is :null);
  test-parse(`"asdf"`    , fn j. j is :str("asdf"));
  test-parse(`"as\"df"`  , fn j. j is :str("as\"df"));
  test-parse(`"as\\\\df"`, fn j. j is :str("as\\df"));
  test-parse(`""`        , fn j. j is :str(""));
  test-parse(`  ""`      , fn j. j is :str(""));

  test-parse(`false`, fn j. j is :bool(false));
  test-parse(`true`,  fn j. j is :bool(true));
  test-parse(`\{}`,   fn j. j is :object(m) and m.is-empty());
  test-parse(
    `\{ "foo": true, "baz": false }`,
    fn j. j is :object(m) and
        m.map(fn f. f.key) == ["foo", "baz"] and
        m.map(fn f. f.value.as-bool().!) == [true, false]
  );

  test-parse(" [ ] ", fn j. j is :array(es) and es.is-empty());
  //test-parse(`[]`, fn j. j is :array(_));
}

fn test() {
  test-basic-enum();
  test-parsing();
  test-parse(example-json, fn o. {
    o is :object(members)
    and members.len() == 5
  });
}

fn test-parse(s: string, f: some fn json -> bool) {
  switch json/parse-from-string(s) {
    :err(msg) -> crash("Failed: {msg}"),
    :ok(json) -> if not f(json) crash("Failed '{s}'")
  }
}

let example-json: string =
`\{
  "school": "Greenwood High",
  "location": \{
    "city": "New York",
    "state": "NY"
  },
  "students": [
    \{
      "name": "Emma",
      "age": 15,
      "grade": "10"
    },
    \{
      "name": "Liam",
      "age": 14,
      "grade": "9"
    },
    \{
      "name": "Olivia",
      "age": 16,
      "grade": "11"
    }
  ],
  "active": true,
  "principal": null
}`


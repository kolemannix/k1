ns json_test;
use std/json/json
use std/json

fn testBasicEnum() {
  let size = core/types/size-of[json]();
  let align = core/types/align-of[json]();
  assertEquals(size, 32);
  assertEquals(align, 8);

  let obj: json = .str("hello");
  let null: json = .null;
  assert(obj is .str("hello"));
  assert(null is .null);

  let obj2: json = .array([.str("hello"), .number(123.0)]);
  assert(obj2.asArray().!.get(0) is .str("hello"));
  assert(obj2.asArray().!.get(1) is .number(123.0));
}

fn testParsing() {
  testParse(`null`      , \j. j is .null);
  testParse(`"asdf"`    , \j. j is .str("asdf"));
  testParse(`"as\"df"`  , \j. j is .str("as\"df"));
  testParse(`"as\\\\df"`, \j. j is .str("as\\df"));
  testParse(`""`        , \j. j is .str(""));
  testParse(`  ""`      , \j. j is .str(""));

  testParse(`false`, \j. j is .bool(false));
  testParse(`true`,  \j. j is .bool(true));
  testParse(`{{}`,   \j. j is .object(m) and m.isEmpty());
  testParse(
    `{{ "foo": true, "baz": false }`,
    \j. j is .object(m) and
        m.map(\f. f.key) == ["foo", "baz"] and
        m.map(\f. f.value.asBool().!) == [true, false]
  );

  testParse(" [ ] ", \j. j is .array(es) and es.isEmpty());
  //testParse(`[]`, \j. j is .Array(_));
}

fn test() {
  testBasicEnum();
  testParsing();
  testParse(example-json, \o. {
    o is .object(members)
    and members.len() == 5
  });
}

fn testParse(s: string, f: some \json -> bool) {
  switch json/parse-from-string(s) {
    .err(msg) -> crash("Failed: {msg}"),
    .ok(json) -> if not f(json) crash("Failed '{s}'")
  }
}

let example-json: string =
`{{
  "school": "Greenwood High",
  "location": {{
    "city": "New York",
    "state": "NY"
  },
  "students": [
    {{
      "name": "Emma",
      "age": 15,
      "grade": "10"
    },
    {{
      "name": "Liam",
      "age": 14,
      "grade": "9"
    },
    {{
      "name": "Olivia",
      "age": 16,
      "grade": "11"
    }
  ],
  "active": true,
  "principal": null
}`

